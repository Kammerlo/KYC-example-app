# ── Connection ──────────────────────────────────────────────────────────────
# Yaci-devkit default; replace with Blockfrost endpoint for pre-prod / mainnet
BLOCKFROST_URL=http://localhost:8080/api/v1/
BLOCKFROST_PROJECT_ID=localnet

# ── Account 1: Protocol Deployer / Issuer ───────────────────────────────────
# This account initialises the Trusted Entity List (TEL) and is its sole admin.
# It is the only key allowed to add/remove entries from the TEL.
ISSUER_MNEMONIC=test test test test test test test test test test test test test test test test test test test test test test test sauce

# ── Account 2: Trusted Entity ───────────────────────────────────────────────
# Added to the TEL by the issuer.
# Can endorse users off-chain so they may add themselves to the KYC Whitelist.
# Also allowed to toggle the active flag on any whitelist node.
ENTITY_MNEMONIC=<24-word BIP39 mnemonic for account 2>

# ── Account 3: End User ──────────────────────────────────────────────────────
# Will be added to the KYC Whitelist using the entity's off-chain endorsement.
USER_MNEMONIC=<24-word BIP39 mnemonic for account 3>

# ── Faucet (yaci-devkit only) ─────────────────────────────────────────────────
# Used by scripts to fund the other wallets in a local devnet session.
# Comment out / remove for public networks.
FAUCET_MNEMONIC=test test test test test test test test test test test test test test test test test test test test test test test sauce

# ── Oneshot bootstrap UTxO references ─────────────────────────────────────────
# These are written automatically on the first successful run of
# InitTrustedEntityList (TE_BOOT_*) and AddUserToWhitelist (WL_BOOT_*).
# They ensure the same policy id is reconstructed on every subsequent run so
# that idempotency checks work correctly.
# DO NOT change these after the contracts have been deployed.
TE_BOOT_TXHASH=<64-char hex tx hash>
TE_BOOT_INDEX=<output index integer>
WL_BOOT_TXHASH=<64-char hex tx hash>
WL_BOOT_INDEX=<output index integer>
